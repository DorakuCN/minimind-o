# Conservative fallback: about 939M params, lower micro-batches.
# Use when dense_1b.env OOMs even with gradient checkpointing.

WEIGHT_PREFIX="${WEIGHT_PREFIX:-omni1b_safe_d2048l16_t1024}"
RUN_GROUP="${RUN_GROUP:-omni1b_safe_d2048l16_t1024}"
NUM_HIDDEN_LAYERS="${NUM_HIDDEN_LAYERS:-16}"
BRIDGE_LAYER="${BRIDGE_LAYER:-7}"
BATCH_T2A="${BATCH_T2A:-6}"
BATCH_A2A_PROJ="${BATCH_A2A_PROJ:-3}"
BATCH_A2A_FULL="${BATCH_A2A_FULL:-3}"
BATCH_I2T_PROJ="${BATCH_I2T_PROJ:-6}"
BATCH_I2T_FULL="${BATCH_I2T_FULL:-6}"
ACCUMULATION_STEPS="${ACCUMULATION_STEPS:-10}"

. "$(dirname "${BASH_SOURCE[0]}")/dense_1b.env"

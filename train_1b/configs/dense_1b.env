# MiniMind-O 1B dense default for 3 x RTX 5090D 32G.
# Source this file from train_1b/run_1b_dense_3gpu.sh.

WEIGHT_PREFIX="${WEIGHT_PREFIX:-omni1b_dense_d2048l18_t1024}"
RUN_GROUP="${RUN_GROUP:-omni1b_dense_d2048l18_t1024}"
WANDB_PROJECT="${WANDB_PROJECT:-MiniMind-O-1B}"

# Architecture: about 1.044B trainable/non-frozen Omni params.
HIDDEN_SIZE="${HIDDEN_SIZE:-2048}"
NUM_HIDDEN_LAYERS="${NUM_HIDDEN_LAYERS:-18}"
NUM_ATTENTION_HEADS="${NUM_ATTENTION_HEADS:-16}"
NUM_KEY_VALUE_HEADS="${NUM_KEY_VALUE_HEADS:-8}"
HEAD_DIM="${HEAD_DIM:-128}"
INTERMEDIATE_SIZE="${INTERMEDIATE_SIZE:-6464}"
BRIDGE_LAYER="${BRIDGE_LAYER:-8}"

TALKER_HIDDEN_SIZE="${TALKER_HIDDEN_SIZE:-1024}"
NUM_TALKER_HIDDEN_LAYERS="${NUM_TALKER_HIDDEN_LAYERS:-4}"
TALKER_NUM_ATTENTION_HEADS="${TALKER_NUM_ATTENTION_HEADS:-8}"
TALKER_NUM_KEY_VALUE_HEADS="${TALKER_NUM_KEY_VALUE_HEADS:-4}"
TALKER_HEAD_DIM="${TALKER_HEAD_DIM:-128}"
TALKER_INTERMEDIATE_SIZE="${TALKER_INTERMEDIATE_SIZE:-3264}"

# Keep MoE off for the first 1B baseline. DDP keeps every expert resident.
USE_MOE="${USE_MOE:-0}"
GRADIENT_CHECKPOINTING="${GRADIENT_CHECKPOINTING:-1}"

# First 1B run favors stability over compile throughput.
COMPILE_T2A="${COMPILE_T2A:-0}"
COMPILE_A2A_PROJ="${COMPILE_A2A_PROJ:-0}"
COMPILE_A2A_FULL="${COMPILE_A2A_FULL:-0}"
COMPILE_I2T_PROJ="${COMPILE_I2T_PROJ:-0}"
COMPILE_I2T_ALL="${COMPILE_I2T_ALL:-0}"
COMPILE_A2A_FINAL="${COMPILE_A2A_FINAL:-0}"
COMPILE_I2T_FINAL="${COMPILE_I2T_FINAL:-0}"

# Existing full data, rank-sharded across 3 GPUs.
DATA_T2A="${DATA_T2A:-../dataset/sft_t2a.parquet}"
DATA_A2A="${DATA_A2A:-../dataset/sft_a2a.parquet}"
DATA_I2T="${DATA_I2T:-../dataset/sft_i2t.parquet}"
RANK_SHARDED_DATA="${RANK_SHARDED_DATA:-1}"

SEQ_T2A="${SEQ_T2A:-512}"
SEQ_A2A="${SEQ_A2A:-1024}"
SEQ_I2T="${SEQ_I2T:-768}"

# Per-GPU micro-batches. Increase one stage at a time after smoke telemetry.
BATCH_T2A="${BATCH_T2A:-8}"
BATCH_A2A_PROJ="${BATCH_A2A_PROJ:-4}"
BATCH_A2A_FULL="${BATCH_A2A_FULL:-4}"
BATCH_I2T_PROJ="${BATCH_I2T_PROJ:-8}"
BATCH_I2T_FULL="${BATCH_I2T_FULL:-8}"
ACCUMULATION_STEPS="${ACCUMULATION_STEPS:-8}"

# Run-E-informed quality defaults: keep Phase-0, revert RVQ to uniform.
WARMUP_RATIO="${WARMUP_RATIO:-0.02}"
LOSS_NORM="${LOSS_NORM:-global}"
RVQ_LAYER_WEIGHTS="${RVQ_LAYER_WEIGHTS:-1,1,1,1,1,1,1,1}"
AUDIO_STOP_WEIGHT="${AUDIO_STOP_WEIGHT:-10}"
VAL_INTERVAL="${VAL_INTERVAL:-500}"
VAL_DATA_T2A="${VAL_DATA_T2A:-../dataset/_val/sft_t2a_val.parquet}"
VAL_DATA_A2A="${VAL_DATA_A2A:-../dataset/_val/sft_a2a_val.parquet}"
VAL_DATA_I2T="${VAL_DATA_I2T:-../dataset/_val/sft_i2t_val.parquet}"

# 1B SFT LRs are intentionally lower than the 113M dense baseline.
LR_T2A="${LR_T2A:-2e-4}"
LR_A2A_PROJ="${LR_A2A_PROJ:-3e-4}"
LR_A2A_FULL="${LR_A2A_FULL:-2e-5}"
LR_I2T_PROJ="${LR_I2T_PROJ:-3e-5}"
LR_I2T_ALL="${LR_I2T_ALL:-2e-6}"
LR_A2A_FINAL="${LR_A2A_FINAL:-2e-6}"
LR_I2T_FINAL="${LR_I2T_FINAL:-2e-6}"

MUON_LR_T2A="${MUON_LR_T2A:-0.01}"
MUON_LR_A2A_PROJ="${MUON_LR_A2A_PROJ:-0.003}"
MUON_LR_A2A_FULL="${MUON_LR_A2A_FULL:-0.001}"
MUON_LR_I2T_PROJ="${MUON_LR_I2T_PROJ:-0.001}"
MUON_LR_I2T_ALL="${MUON_LR_I2T_ALL:-0.0005}"
MUON_LR_A2A_FINAL="${MUON_LR_A2A_FINAL:-0.0005}"
MUON_LR_I2T_FINAL="${MUON_LR_I2T_FINAL:-0.0005}"

# Keep the useful longer I2T schedule, then end on A2A by default.
EPOCHS_T2A="${EPOCHS_T2A:-6}"
EPOCHS_A2A_PROJ="${EPOCHS_A2A_PROJ:-1}"
EPOCHS_A2A_FULL="${EPOCHS_A2A_FULL:-3}"
EPOCHS_I2T_PROJ="${EPOCHS_I2T_PROJ:-2}"
EPOCHS_I2T_ALL="${EPOCHS_I2T_ALL:-2}"
EPOCHS_A2A_FINAL="${EPOCHS_A2A_FINAL:-2}"
EPOCHS_I2T_FINAL="${EPOCHS_I2T_FINAL:-0}"
END_STAGE="${END_STAGE:-6}"

DDP_BROADCAST_BUFFERS="${DDP_BROADCAST_BUFFERS:-0}"
FINITE_GUARD="${FINITE_GUARD:-1}"
FINITE_GUARD_LOGITS_INTERVAL="${FINITE_GUARD_LOGITS_INTERVAL:-0}"
NUM_WORKERS="${NUM_WORKERS:-8}"
LOG_INTERVAL="${LOG_INTERVAL:-50}"
SAVE_INTERVAL="${SAVE_INTERVAL:-1000}"
MAX_TRAIN_STEPS="${MAX_TRAIN_STEPS:-0}"
